# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://art_rium:changeme@localhost:5432/art_rium

# ── ComfyUI ───────────────────────────────────────────────────────────────────
COMFYUI_HOST=127.0.0.1:8188
COMFYUI_OUTPUT_DIR=E:/00_comfy/output

# ── Storage (managed ingested files) ─────────────────────────────────────────
# Defaults to ./storage — override if you want files elsewhere
# STORAGE_DIR=D:/art-rium-storage

# ── Auth ──────────────────────────────────────────────────────────────────────
API_KEY=your-generated-key-here

# ── WordPress ─────────────────────────────────────────────────────────────────
WP_BASE_URL=xxx
WP_USERNAME=xxx
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# Polylang default language code — used as ?lang= when uploading media
WP_DEFAULT_LANGUAGE=en

# ── Ollama (local VLM for image analysis at upload time) ─────────────────────
OLLAMA_HOST=http://localhost:11434
# Must be vision-capable. Default qwen2.5vl:7b is fast and accurate enough
# for alt-text + SEO copy. Heavier alternatives: qwen2.5vl:32b, qwen3-vl
OLLAMA_VLM_MODEL=qwen2.5vl:latest
# Source images are downscaled to this edge before being sent to the VLM
# (the full 1080px JPG still goes to WordPress)
VLM_ANALYSIS_MAX_EDGE=512

# ── Public URL (needed for Instagram to fetch images) ─────────────────────────
# PUBLIC_BASE_URL=https://xyz.trycloudflare.com

# ── Instagram (optional) ──────────────────────────────────────────────────────
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
IMAGE_SHARE_TOKEN=

# ── YouTube (optional — used by the Articles tool to embed videos) ───────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# (Desktop app). After filling client_id/secret, run:
#     python scripts/youtube_auth.py
# which opens a browser, captures consent, and writes YOUTUBE_REFRESH_TOKEN
# back into this file.
#
# IMPORTANT: set the OAuth consent screen to "In production" (NOT "Testing")
# in Google Cloud Console, otherwise the refresh token expires after 7 days.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_DEFAULT=public
