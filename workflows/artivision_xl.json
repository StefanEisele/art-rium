{
  "1": {
    "inputs": {"ckpt_name": "sdxl\\artivisionxl_Mixv1.safetensors"},
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load Checkpoint"}
  },
  "2": {
    "inputs": {
      "lora_name": "xl_more_art-full_v1.safetensors",
      "strength_model": 1,
      "strength_clip": 0,
      "model": ["1", 0],
      "clip": ["1", 1]
    },
    "class_type": "LoraLoader",
    "_meta": {"title": "Load LoRA"}
  },
  "3": {
    "inputs": {
      "text": "a beautiful landscape",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Text Encode (Positive)"}
  },
  "4": {
    "inputs": {
      "text": "worst quality, low quality, blurry, jpeg artifacts, watermark, text, signature, deformed, disfigured, bad anatomy, extra limbs, extra fingers, mutated hands, cropped, out of frame",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Text Encode (Negative)"}
  },
  "5": {
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Empty Latent Image (base pass)"}
  },
  "6": {
    "inputs": {
      "seed": 0,
      "steps": 25,
      "cfg": 2.5,
      "sampler_name": "euler_ancestral",
      "scheduler": "karras",
      "denoise": 1,
      "model": ["2", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler (base)"}
  },
  "7": {
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode (base)"}
  },
  "8": {
    "inputs": {"model_name": "4x-UltraSharp.pth"},
    "class_type": "UpscaleModelLoader",
    "_meta": {"title": "Load Upscale Model"}
  },
  "9": {
    "inputs": {
      "upscale_model": ["8", 0],
      "image": ["7", 0]
    },
    "class_type": "ImageUpscaleWithModel",
    "_meta": {"title": "Upscale Image (4x-UltraSharp)"}
  },
  "10": {
    "inputs": {
      "image": ["9", 0],
      "upscale_method": "lanczos",
      "width": 1024,
      "height": 1024,
      "crop": "disabled"
    },
    "class_type": "ImageScale",
    "_meta": {"title": "Resize to target"}
  },
  "11": {
    "inputs": {
      "pixels": ["10", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEEncode",
    "_meta": {"title": "VAE Encode (hires)"}
  },
  "12": {
    "inputs": {
      "seed": 0,
      "steps": 14,
      "cfg": 2.5,
      "sampler_name": "euler_ancestral",
      "scheduler": "karras",
      "denoise": 0.35,
      "model": ["2", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["11", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler (hires-fix)"}
  },
  "13": {
    "inputs": {
      "samples": ["12", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode (hires)"}
  },
  "14": {
    "inputs": {
      "filename_prefix": "artivision-xl",
      "images": ["13", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  }
}
